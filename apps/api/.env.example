# Database
DATABASE_URL=postgresql://user:password@localhost:5432/spendwise?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-at-least-32-random-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-at-least-32-random-characters-different
JWT_REFRESH_EXPIRES_IN=7d

# AI - Gemini chat + embeddings
GEMINI_API_KEY=AQ...

# Email - Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
